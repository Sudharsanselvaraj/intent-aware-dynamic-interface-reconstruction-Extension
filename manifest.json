{
  "manifest_version": 3,
  "name": "Reality Layer",
  "version": "1.0.0",
  "description": "You decide how every website looks and behaves — a personal UI layer on top of every website",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/js/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/html/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/js/modules/dark-pattern-detector.js",
        "src/js/modules/memory-graph.js",
        "src/js/modules/intent-inference.js",
        "src/js/modules/gemini-intent-detector.js",
        "src/js/content_script.js"
      ],
      "css": ["src/css/overlay.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "src/assets/icon-16.png",
    "32": "src/assets/icon-32.png",
    "48": "src/assets/icon-48.png",
    "128": "src/assets/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/css/overlay.css"],
      "matches": ["<all_urls>"]
    }
  ]
}